{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Analysis Response",
  "type": "object",
  "additionalProperties": true,
  "required": ["run_id", "status"],
  "properties": {
    "run_id": {"type": "string"},
    "status": {"type": "string"},
    "summary": {"type": "object"},
    "evidence_results": {"type": "array"},
    "workbook_results": {"type": "array"},
    "gap_tickets": {"type": "array"},
    "errors": {"type": "array"}
  }
}
